# Local file storage (default)
STORAGE_BACKEND=file
DEMO_MODE=false
HISTORY_ENABLED=true

# Firebase production (Cloud Run)
# STORAGE_BACKEND=firestore
# FIREBASE_PROJECT_ID=ssh-analyzer
# FIREBASE_AUTH_REQUIRED=true
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# SSH_PRIVATE_KEY_PATH=/path/to/key

# CORS (comma-separated origins for Firebase Hosting)
# CORS_ORIGINS=https://your-project-id.web.app,https://your-project-id.firebaseapp.com
